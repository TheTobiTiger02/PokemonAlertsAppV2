<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@drawable/widget_bg"
    android:gravity="center">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/img_logo_compact"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginEnd="8dp"
            android:src="@drawable/ic_poke_notification"
            android:contentDescription="@string/widget_logo_cd"
            android:tint="@color/poke_red" />

        <TextView
            android:id="@+id/tv_title_compact"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/widget_title"
            android:textStyle="bold"
            android:textSize="14sp"
            android:textColor="@color/poke_white"
            android:maxLines="1"
            android:ellipsize="end" />

        <ImageButton
            android:id="@+id/btn_refresh_compact"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:background="@android:color/transparent"
            android:contentDescription="@string/refresh_alerts"
            android:tint="@color/poke_blue"
            android:src="@drawable/ic_refresh" />
    </LinearLayout>

    <!-- Count display -->
    <TextView
        android:id="@+id/tv_compact_count"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="@color/poke_blue"
        android:layout_marginTop="8dp"
        android:maxLines="1" />

    <TextView
        android:id="@+id/tv_compact_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="12sp"
        android:textColor="@color/poke_light_gray"
        android:text="active alerts"
        android:layout_marginTop="2dp"
        android:maxLines="1" />

</LinearLayout>
