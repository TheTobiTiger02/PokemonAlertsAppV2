<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@drawable/widget_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="4dp">

        <ImageView
            android:id="@+id/img_logo"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginEnd="8dp"
            android:src="@drawable/ic_widget_pokeball"
            android:contentDescription="@string/widget_logo_cd" />

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/widget_title"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="@color/widget_on_surface"
            android:maxLines="1"
            android:ellipsize="end" />

        <!-- Active count badge -->
        <TextView
            android:id="@+id/tv_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/widget_primary"
            android:layout_marginEnd="8dp"
            android:maxLines="1" />

        <ImageButton
            android:id="@+id/btn_map"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/widget_icon_button_background"
            android:contentDescription="@string/widget_open_map_cd"
            android:tint="@color/widget_primary"
            android:src="@drawable/ic_map"
            android:padding="10dp"
            android:layout_marginEnd="8dp" />

        <ImageButton
            android:id="@+id/btn_refresh"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/widget_icon_button_background"
            android:contentDescription="@string/refresh_alerts"
            android:tint="@color/widget_primary"
            android:src="@drawable/ic_refresh"
            android:padding="10dp" />
    </LinearLayout>

    <TextView
        android:id="@+id/tv_last_updated"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="12sp"
        android:textColor="@color/widget_on_surface_variant"
        android:maxLines="1"
        android:ellipsize="end"
        android:paddingBottom="8dp"
        android:text="" />

    <!-- Empty state with icon -->
    <LinearLayout
        android:id="@+id/empty_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingTop="24dp"
        android:paddingBottom="24dp"
        android:visibility="gone">

        <ImageView
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_placeholder"
            android:contentDescription="@null"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/tv_empty_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/widget_on_surface"
            android:text="@string/widget_empty_title"
            android:gravity="center"
            android:textStyle="bold"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tv_empty_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/widget_on_surface_variant"
            android:text="@string/widget_empty_subtitle"
            android:gravity="center"
            android:textSize="12sp"
            android:layout_marginTop="4dp" />
    </LinearLayout>

    <!-- Hidden empty view for ListView's setEmptyView -->
    <TextView
        android:id="@+id/tv_empty"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />

    <ListView
        android:id="@+id/list_alerts"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:divider="@android:color/transparent"
        android:dividerHeight="10dp"
        android:transcriptMode="alwaysScroll"
        android:scrollbars="none" />

</LinearLayout>
