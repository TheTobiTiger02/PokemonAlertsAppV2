<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/pair_second"
    android:layout_width="match_parent"
    android:layout_height="0dp"
    android:layout_weight="1"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="10dp"
    android:background="@drawable/widget_item_background">
    <FrameLayout android:id="@+id/pair_second_bar" android:layout_width="4dp" android:layout_height="match_parent" android:layout_marginEnd="8dp" android:background="@color/widget_primary" />
    <ImageView android:id="@+id/pair_second_image" android:layout_width="88dp" android:layout_height="88dp" android:layout_marginEnd="12dp" android:scaleType="centerCrop" android:background="@drawable/widget_image_bg" android:clipToOutline="true" android:contentDescription="@string/alert_image" />
    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
        <TextView android:id="@+id/pair_second_title" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="17sp" android:textStyle="bold" android:textColor="@color/widget_on_surface" android:maxLines="2" android:ellipsize="end" />
        <TextView android:id="@+id/pair_second_meta" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="5dp" android:textSize="13sp" android:textStyle="bold" android:textColor="@color/widget_primary" android:maxLines="1" />
        <TextView android:id="@+id/pair_second_countdown" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="5dp" android:textSize="13sp" android:textStyle="bold" android:textColor="@color/widget_warning" android:maxLines="1" />
    </LinearLayout>
</LinearLayout>
